{
  "datasets": [
    {
      "name": "ds_summary",
      "displayName": "Overall Summary",
      "queryLines": [
        "SELECT COUNT(DISTINCT r.DQ_RULE_NO) AS TOTAL_RULES, COUNT(DISTINCT CASE WHEN r.DQ_NUMBER_RELEVANT_RECORDS > 0 THEN r.DQ_RULE_NO END) AS RULES_APPLIED, COUNT(DISTINCT CASE WHEN r.DQ_NUMBER_RELEVANT_RECORDS = 0 THEN r.DQ_RULE_NO END) AS RULES_SKIPPED, SUM(r.DQ_NUMBER_RELEVANT_RECORDS) AS TOTAL_CHECKS, SUM(r.DQ_NUMBER_POS_RESULTS) AS TOTAL_PASSED, SUM(r.DQ_NUMBER_RELEVANT_RECORDS - r.DQ_NUMBER_POS_RESULTS) AS TOTAL_FAILED, ROUND(SUM(r.DQ_NUMBER_POS_RESULTS)*1.0/NULLIF(SUM(r.DQ_NUMBER_RELEVANT_RECORDS),0)*100,2) AS OVERALL_PASS_PCT, DATE_FORMAT(MAX(r.DQ_EXECUTION_TIMESTAMP), 'yyyy-MM-dd HH:mm') AS LAST_RUN FROM databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_results r WHERE r.DQ_EXECUTION_TIMESTAMP = (SELECT MAX(DQ_EXECUTION_TIMESTAMP) FROM databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_results)"
      ]
    },
    {
      "name": "ds_by_category",
      "displayName": "By Category",
      "queryLines": [
        "SELECT COALESCE(m.dq_category, g.dq_category) AS DQ_CATEGORY, COUNT(DISTINCT r.DQ_RULE_NO) AS TOTAL_RULES, SUM(r.DQ_NUMBER_RELEVANT_RECORDS) AS TOTAL_CHECKS, SUM(r.DQ_NUMBER_POS_RESULTS) AS TOTAL_PASSED, SUM(r.DQ_NUMBER_RELEVANT_RECORDS - r.DQ_NUMBER_POS_RESULTS) AS TOTAL_FAILED, ROUND(SUM(r.DQ_NUMBER_POS_RESULTS)*1.0/NULLIF(SUM(r.DQ_NUMBER_RELEVANT_RECORDS),0)*100,2) AS PASS_PCT FROM databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_results r JOIN databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_rule_mappings m ON r.DQ_RULE_NO = m.rule_no JOIN databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_rules_generic g ON m.generic_rule_desc_short = g.generic_rule_desc_short WHERE r.DQ_EXECUTION_TIMESTAMP = (SELECT MAX(DQ_EXECUTION_TIMESTAMP) FROM databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_results) GROUP BY COALESCE(m.dq_category, g.dq_category) ORDER BY DQ_CATEGORY"
      ]
    },
    {
      "name": "ds_rule_detail",
      "displayName": "Per-Rule Detail",
      "queryLines": [
        "SELECT r.DQ_RULE_NO, COALESCE(m.dq_category, g.dq_category) AS DQ_CATEGORY, m.source_field AS SOURCE_FIELD, g.generic_rule_desc_short AS RULE_TYPE, m.rule_description AS RULE_DESC, r.DQ_NUMBER_RELEVANT_RECORDS AS CHECKS, r.DQ_NUMBER_POS_RESULTS AS PASSED, r.DQ_NUMBER_RELEVANT_RECORDS - r.DQ_NUMBER_POS_RESULTS AS FAILED, ROUND(r.DQ_NUMBER_POS_RESULTS*1.0/NULLIF(r.DQ_NUMBER_RELEVANT_RECORDS,0)*100,2) AS PASS_PCT, CASE WHEN r.DQ_NUMBER_RELEVANT_RECORDS = 0 THEN 'SKIPPED'      WHEN r.DQ_NUMBER_POS_RESULTS = r.DQ_NUMBER_RELEVANT_RECORDS THEN 'PASS'      ELSE 'BREACH' END AS STATUS, m.threshold_pct AS THRESHOLD_PCT, m.owner_dept AS OWNER_DEPT, m.owner_user AS OWNER_USER FROM databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_results r JOIN databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_rule_mappings m ON r.DQ_RULE_NO = m.rule_no JOIN databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_rules_generic g ON m.generic_rule_desc_short = g.generic_rule_desc_short WHERE r.DQ_EXECUTION_TIMESTAMP = (SELECT MAX(DQ_EXECUTION_TIMESTAMP) FROM databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_results) ORDER BY DQ_CATEGORY, r.DQ_RULE_NO"
      ]
    },
    {
      "name": "ds_breach_register",
      "displayName": "Breach Register",
      "queryLines": [
        "SELECT r.DQ_RULE_NO, COALESCE(m.dq_category, g.dq_category) AS DQ_CATEGORY, m.source_field AS SOURCE_FIELD, m.rule_description AS RULE_DESC, r.DQ_NUMBER_RELEVANT_RECORDS AS CHECKS, r.DQ_NUMBER_POS_RESULTS AS PASSED, r.DQ_NUMBER_RELEVANT_RECORDS - r.DQ_NUMBER_POS_RESULTS AS FAILED_RECORDS, ROUND(r.DQ_NUMBER_POS_RESULTS*1.0/NULLIF(r.DQ_NUMBER_RELEVANT_RECORDS,0)*100,2) AS PASS_PCT, m.threshold_pct AS REQUIRED_PCT, m.owner_dept AS OWNER_DEPT, m.owner_user AS OWNER_USER FROM databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_results r JOIN databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_rule_mappings m ON r.DQ_RULE_NO = m.rule_no JOIN databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_rules_generic g ON m.generic_rule_desc_short = g.generic_rule_desc_short WHERE r.DQ_EXECUTION_TIMESTAMP = (SELECT MAX(DQ_EXECUTION_TIMESTAMP) FROM databricks_snippets_7405610928938750.dbdemos_dq_business_arausch.dq_results)   AND r.DQ_NUMBER_RELEVANT_RECORDS > 0   AND ROUND(r.DQ_NUMBER_POS_RESULTS*1.0/r.DQ_NUMBER_RELEVANT_RECORDS*100,2) < m.threshold_pct ORDER BY PASS_PCT ASC"
      ]
    }
  ],
